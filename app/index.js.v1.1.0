const express = require("express");
const app = express();

const VERSION = "v1.1.0";

app.get("/", (req, res) => {
  res.json({
    status: "healthy",
    version: VERSION
  });
});

app.get("/health", (req, res) => {
  res.json({
    status: "ok",
    version: VERSION
  });
});

const PORT = process.env.PORT || 5000;
app.listen(PORT, () => {
  console.log(`API running on port ${PORT}, version ${VERSION}`);
});